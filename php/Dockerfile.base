FROM php:8.5.2-fpm-alpine

COPY conf.d/*.ini $PHP_INI_DIR/conf.d/

RUN mv "$PHP_INI_DIR/php.ini-production" "$PHP_INI_DIR/php.ini"

RUN apk update \
  && apk add --no-cache \
  icu-dev=76.1-r1 \
  zlib-dev=1.3.1-r2 \
  libpng-dev=1.6.54-r0 \
  bzip2-dev=1.0.8-r6 \
  libzip-dev=1.11.4-r0 \
  openldap-dev=2.6.8-r0 \
  && docker-php-ext-install \
  intl mysqli gd exif bz2 zip ldap opcache bcmath \
  && apk add --no-cache --virtual .build-deps \
  autoconf=2.72-r1 \
  dpkg-dev=1.22.15-r0 \
  dpkg=1.22.15-r0 \
  file=5.46-r2 \
  g++=14.2.0-r6 \
  gcc=14.2.0-r6 \
  musl-dev=1.2.5-r10 \
  make=4.4.1-r3 \
  pkgconf=2.4.3-r0 \
  re2c=4.2-r0 \
  && pecl install redis \
  && docker-php-ext-enable redis \
  && apk del .build-deps

RUN docker-php-source delete

EXPOSE 9000/tcp 

CMD ["php-fpm"]

